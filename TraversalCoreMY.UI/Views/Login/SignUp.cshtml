@model UserRegisterViewModel
<!DOCTYPE html>
<html lang="tr">

<head>
    <title>Invent Kayıt Formu | Ana Sayfa :: W3layouts</title>
    <!-- Meta tag Keywords -->
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta charset="UTF-8" />
<meta name="keywords"
      content="Invent Kayıt Formu, Responsive web template, Bootstrap Web Templates, Flat Web Templates, Android Compatible web template, Smartphone Compatible web template, free webdesigns for Nokia, Samsung, LG, SonyEricsson, Motorola web design" />
<script>
    addEventListener("load", function () {
        setTimeout(hideURLbar, 0);
    }, false);

    function hideURLbar() {
        window.scrollTo(0, 1);
    }
</script>
<!-- //Meta tag Keywords -->
<!--/Style-CSS -->
<link rel="stylesheet" href="~/web/css/style.css" type="text/css" media="all" />
<!--//Style-CSS -->
</head>

<body>
    <!-- /login-section -->
    <section class="w3l-login-6">
        <div class="login-hny">
            <div class="form-content">
                <div class="form-right">
                    <div class="overlay">
                        <div class="grid-info-form">
                            <h5>Merhaba deyin</h5>
                            <h3>HESAP OLUŞTUR</h3>
                            <p>
                                Lorem ipsum dolor sit amet, consectetur adipisicing elit. Est natus facere aperiam!
                                Tenetur maiores dolore a quod pariatur ut voluptates quae saepe ea quasi laudantium,
                                iste molestias inventore fuga assumenda.
                            </p>
                            <a href="index.html" class="read-more-1 btn">Başlayın</a>
                        </div>
                    </div>
                </div>
                <div class="form-left">
                    <div class="middle">
                        <h4>Bize Katılın</h4>
                        <p>Hesabınızı oluşturun, Ücretsizdir.</p>
                    </div>
                    <form action="#" method="post" class="signin-form">
                        <div class="form-input">
                            <label>Adınız</label>
                            <input type="text" asp-for="Name" placeholder="Adınız" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="form-input">
                            <label>Soyadınız</label>
                            <input type="text" asp-for="Surname" placeholder="Soyadınız" required />
                            <span asp-validation-for="Surname" class="text-danger"></span>
                        </div>
                        <div class="form-input">
                            <label>Email</label>
                            <input type="email" asp-for="Mail" placeholder="Email" required />
                            <span asp-validation-for="Mail" class="text-danger"></span>
                        </div>
                        <div class="form-input">
                            <label>Şifre</label>
                            <input type="password" asp-for="Password" placeholder="Şifre" required />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="form-input">
                            <label>Şifre Tekrar</label>
                            <input type="password" asp-for="ConfirmPassword" placeholder="Şifre Tekrar" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                        <span asp-validation-summary="ModelOnly" class="text-danger"></span>
                        <label class="container">
                            Kullanım Şartları ve Gizlilik Politikası'nı <a href="#">kabul ediyorum</a>.
                            <input type="checkbox" required>
                            <span class="checkmark"></span>
                        </label>

                        <button class="btn">Hesap Oluştur</button>

                    </form>
                    <div class="copy-right text-center">
                        <p>
                            © 2019 Invent Kayıt. Tüm hakları saklıdır | Tasarım:
                            <a href="http://w3layouts.com/" target="_blank">W3layouts</a>
                        </p>
                    </div>
                </div>

            </div>

        </div>
    </section>
    <!-- //login-section -->
</body>

</html>
